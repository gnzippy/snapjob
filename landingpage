      <p>First 50 businesses get 6 months free. We'll WhatsApp you to get set up — takes 10 minutes.</p>
      <div class="fg"><label>Your name</label><input type="text" id="m-name" class="fi" placeholder="e.g. Ahmad"></div>
      <div class="fg"><label>Business name</label><input type="text" id="m-biz" class="fi" placeholder="e.g. Ahmad Aircon Services"></div>
      <div class="fg"><label>WhatsApp number</label><input type="text" id="m-phone" class="fi" placeholder="+65 or +60..."></div>
      <div class="fg"><label>Type of business</label>
        <select id="m-trade" class="fse">
          <option value="">Select your trade...</option>
          <option>Aircon servicing & repair</option>
          <option>Plumbing</option>
          <option>Electrical</option>
          <option>Appliance repair</option>
          <option>Cleaning</option>
          <option>Renovation</option>
          <option>Other trades</option>
        </select>
      </div>
      <div class="fg"><label>How many technicians?</label><input type="text" id="m-tech" class="fi" placeholder="e.g. 2"></div>
      <button class="modal-sub" onclick="submitWaitlist()">Join waitlist — free</button>
    </div>
    <div class="modal-ok" id="modal-ok">
      <div class="big">✅</div>
      <h4>You're on the list!</h4>
      <p>We'll WhatsApp you within 24 hours to get you set up. First 50 businesses get 6 months free.</p>
    </div>
  </div>
</div>

<script>
function openModal(){document.getElementById('modal').classList.add('open')}
function closeModal(){document.getElementById('modal').classList.remove('open')}
function submitWaitlist(){
  const name=document.getElementById('m-name').value.trim();
  const phone=document.getElementById('m-phone').value.trim();
  if(!name||!phone){alert('Please enter your name and WhatsApp number.');return;}
  document.getElementById('modal-form').style.display='none';
  document.getElementById('modal-ok').style.display='block';
}
// Fade in on scroll
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')})},{threshold:0.1});
document.querySelectorAll('.fi-up').forEach(el=>obs.observe(el));
</script>
